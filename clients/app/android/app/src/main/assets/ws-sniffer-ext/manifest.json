{
  "manifest_version": 2,
  "name": "WebSocket Sniffer",
  "version": "1.0",
  "description": "WebSocket traffic sniffer for weiqi-bot",
  "browser_specific_settings": {
    "gecko": {
      "id": "ws-sniffer@weiqi.app"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons"
  ]
}