{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist/preload",
    "rootDir": "./src/preload",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/preload/**/*"],
  "exclude": ["node_modules", "dist"]
}
