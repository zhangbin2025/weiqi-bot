{
  "name": "weiqi-bot",
  "version": "0.2.0",
  "type": "module",
  "description": "围棋AI助手 - AI-powered Go game assistant",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "clean:all": "rm -rf dist coverage *.tsbuildinfo node_modules",
    "reset": "npm run clean:all && npm install",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint infrastructure --ext .ts",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "dev:build": "vite build && node scripts/build-assets.mjs && find dist-web -name '*.map' -type f -delete",
    "build:web": "vite build && node scripts/build-assets.mjs",
    "build:app": "bash scripts/build-android.sh",
    "help": "node scripts/help.mjs",
    "generate:joseki": "node scripts/generate-joseki-tree.mjs",
    "dev:desktop": "cd clients/desktop && npm run dev",
    "build:desktop": "npm run build:web && cd clients/desktop && npm install && npm run build",
    "dist:desktop": "npm run build:desktop && cd clients/desktop && npx electron-builder --win zip --x64 --config.win.sign=null --config.win.signingHashAlgorithms=[]"
  },
  "keywords": [
    "weiqi",
    "go",
    "baduk",
    "ai",
    "assistant",
    "desktop",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tensorflow/tfjs": "^4.20.0",
    "@tensorflow/tfjs-backend-wasm": "^4.20.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.20.0",
    "@weiqi/worker": "file:../weiqi-worker",
    "@xenova/transformers": "^2.17.2",
    "jszip": "^3.10.1",
    "marked": "^18.0.4",
    "pako": "^2.1.0",
    "puppeteer": "^25.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pako": "^2.0.3",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^1.6.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-native-test-renderer": "^0.0.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.13",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
